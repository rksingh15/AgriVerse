<?xml version="1.0" encoding="utf-8"?>
<androidx.constraintlayout.widget.ConstraintLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    xmlns:tools="http://schemas.android.com/tools"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="#0F172A"> <!-- Deep Dark Background -->

    <!-- Ambient Background Glow -->
    <View
        android:layout_width="300dp"
        android:layout_height="300dp"
        android:background="@drawable/card_ripple"
        android:backgroundTint="#1E40AF"
        android:alpha="0.2"
        app:layout_constraintTop_toTopOf="parent"
        app:layout_constraintEnd_toEndOf="parent"
        android:layout_marginTop="-100dp"
        android:layout_marginEnd="-100dp"/>

    <!-- Header / Title -->
    <TextView
        android:id="@+id/tvHeader"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:text="Julia AI Assistant"
        android:textColor="#FFFFFF"
        android:textSize="20sp"
        android:textStyle="bold"
        android:layout_marginTop="24dp"
        app:layout_constraintTop_toTopOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintEnd_toEndOf="parent"/>

    <!-- AI Response Display Area -->
    <androidx.core.widget.NestedScrollView
        android:id="@+id/scrollInfo"
        android:layout_width="match_parent"
        android:layout_height="0dp"
        android:layout_marginTop="20dp"
        android:layout_marginBottom="24dp"
        android:paddingHorizontal="24dp"
        android:scrollbars="none"
        app:layout_constraintBottom_toTopOf="@id/micOuterCircle"
        app:layout_constraintTop_toBottomOf="@id/tvHeader">

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:gravity="center_horizontal">

            <TextView
                android:id="@+id/tvTitle"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:gravity="center"
                android:text="Tap mic and speak\nHow can I help you today?"
                android:textColor="#94A3B8"
                android:textSize="22sp"
                android:lineSpacingExtra="8dp"
                android:fontFamily="sans-serif-medium"
                android:paddingTop="40dp"/>

        </LinearLayout>
    </androidx.core.widget.NestedScrollView>

    <!-- Pulsing / Static Mic Outer Circle -->
    <FrameLayout
        android:id="@+id/micOuterCircle"
        android:layout_width="120dp"
        android:layout_height="120dp"
        android:layout_marginBottom="60dp"
        android:background="@drawable/card_ripple"
        android:backgroundTint="#334155"
        app:layout_constraintBottom_toTopOf="@id/tvHint"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintStart_toStartOf="parent">

        <androidx.cardview.widget.CardView
            android:id="@+id/micContainer"
            android:layout_width="90dp"
            android:layout_height="90dp"
            android:layout_gravity="center"
            app:cardCornerRadius="45dp"
            app:cardElevation="12dp"
            app:cardBackgroundColor="#2E7D32"
            android:clickable="true"
            android:focusable="true"
            android:foreground="?android:attr/selectableItemBackground">

            <ImageView
                android:id="@+id/imgAiIcon"
                android:layout_width="40dp"
                android:layout_height="40dp"
                android:layout_gravity="center"
                android:src="@drawable/aitechnology"
                app:tint="#FFFFFF" />
        </androidx.cardview.widget.CardView>
    </FrameLayout>

    <TextView
        android:id="@+id/tvHint"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:text="Listening for your voice..."
        android:textColor="#64748B"
        android:textSize="14sp"
        android:layout_marginBottom="40dp"
        app:layout_constraintBottom_toBottomOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintEnd_toEndOf="parent" />

</androidx.constraintlayout.widget.ConstraintLayout>